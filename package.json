{
  "name": "dexterous-server",
  "version": "0.0.0",
  "license": "MIT",
  "description": "",
  "main": "build/js/index.js",
  "module": "build/esm/index.mjs",
  "types": "build/types/index.d.ts",
  "scripts": {
    "fix:prettier": "prettier \"src/**/*.{ts,json}\" --write && prettier \"*.json\" --write",
    "fix": "bun run fix:prettier",
    "dev": "bun --watch run ./src/index.ts",
    "build": "tsup",
    "start": "bun ./src/index.ts",
    "prepublishOnly": "npm run build",
    "publish-directly": "npm publish --access public",
    "auto-release": "npm run fix:prettier && npm run build && release-it"
  },
  "dependensies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-http-proxy": "^1.6.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.5",
    "body-parser": "^2.2.2",
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "express-http-proxy": "^2.1.2",
    "fs-jetpack": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "km-api": "^0.2.4",
    "lodash": "^4.17.23",
    "nanoid": "^5.1.6",
    "zipson": "^0.2.12",
    "zod": "^4.3.6",
    "@types/bun": "latest",
    "bun-types": "^1.3.13",
    "prettier": "^2.1.1",
    "release-it": "^17.6.0",
    "tsup": "^8.5.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=14"
  },
  "files": [
    "build",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "tsup",
    "bun",
    "release",
    "publish",
    "typeScript",
    "km-packages"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./build/esm/index.mjs",
      "require": "./build/cjs/index.cjs",
      "types": "./build/types/index.d.ts"
    }
  },
  "dependencies": {
    "@types/mongoose": "^5.11.97",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "uuid": "^14.0.0"
  }
}
